spring.application.name=bunker

# JWT secret used to sign/verify tokens. Generate your own value, do not reuse this one.
jwt.secret=REPLACE_WITH_YOUR_OWN_SECRET_KEY

spring.datasource.hikari.maximum-pool-size=10

spring.jpa.hibernate.ddl-auto=update

spring.data.redis.host=localhost
spring.data.redis.port=6379
spring.cache.type=redis

spring.datasource.url=jdbc:postgresql://localhost:5432/db?options=-c%20timezone=UTC
spring.datasource.username=your_db_username
spring.datasource.password=your_db_password



# Use a relative, cross-platform path (matches logback-spring.xml), not an absolute Windows path.
logging.file.name=logs/bunker.log

logging.level.root=INFO
logging.level.com.example.bunker=INFO

logging.logback.rollingpolicy.max-file-size=10MB
logging.logback.rollingpolicy.max-history=7